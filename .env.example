# Railway部署环境变量配置
# 复制此文件为.env并设置实际值

# Flask应用密钥（用于session加密）
# 生成强密钥：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# 调试模式（生产环境设置为False）
DEBUG=False

# 服务器端口（Railway自动设置PORT环境变量）
# PORT=5000

# 数据库配置（SQLite路径）
# Railway使用临时文件系统，SQLite数据不会持久化
# 考虑使用PostgreSQL等外部数据库用于生产环境
DATABASE_URL=data/app.db

# CORS允许的源（生产环境应限制为具体域名）
ALLOWED_ORIGINS=*

# Gitee API配置（可选）
# GITEE_ACCESS_TOKEN=your_gitee_token
# GITEE_REPO_URL=https://gitee.com/username/repo