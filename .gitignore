# Python忽略文件
# 忽略Python编译文件
__pycache__/
*.py[cod]
*$py.class

# 忽略虚拟环境
venv/
env/
.virtualenv/

# 忽略IDE文件
.vscode/
.idea/
*.swp
*.swo

# 忽略数据库文件（但data/app.db不忽略，因为SQLite需要）
# data/app.db  # 取消注释这行如果不希望提交数据库文件

# 忽略日志文件
*.log

# 忽略环境变量文件
.env
.env.local

# 忽略上传文件
uploads/

# 忽略操作系统文件
.DS_Store
Thumbs.db